.hero {
  background: linear-gradient(135deg, #0d3b2a 0%, #05a04f 54%, #07c05f 100%);
  color: #ffffff;
  border-radius: 20rpx;
}

.hero .title { color: #ffffff; }

.hero .muted {
  color: rgba(255, 255, 255, 0.75);
}

.section {
  margin-top: 0;
}

.notice {
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid #d0f2de;
  border-radius: 14rpx;
  background: #e9f8ec;
  color: #1f5a3f;
  font-size: 26rpx;
  line-height: 1.5;
}

.picker-value { color: #1a1a1a; }

.status-message {
  margin-top: 12rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 16rpx;
}

.knowledge-item {
  padding: 16rpx 20rpx;
  border: 1rpx solid #e8e8ed;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1a1a1a;
  font-size: 26rpx;
}

.knowledge-item.active {
  border-color: #07c05f;
  background: #e9f8ec;
  color: #05a04f;
  font-weight: 600;
}

.secondary {
  background: #ffffff !important;
  color: #07c05f !important;
  border: 1rpx solid #b8ebcc !important;
}
