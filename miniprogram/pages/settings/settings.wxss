.card { margin-bottom: 20rpx; }

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.toggle-info { flex: 1; }

.toggle-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
}

.toggle-desc {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  margin-top: 4rpx;
  display: block;
}

.picker-value {
  color: #1a1a1a;
  font-size: 28rpx;
}
