.chat-scroll {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 120rpx;
  box-sizing: border-box;
  padding: 16rpx 28rpx;
  background: #f4f6f8;
}

.welcome-area { padding: 0 0; }

.greeting-card {
  padding: 40rpx 28rpx 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.greeting-title {
  font-size: 44rpx; font-weight: 700; color: #1a1a1a;
  display: block; margin-bottom: 12rpx;
}

.greeting-desc {
  font-size: 28rpx; color: rgba(0, 0, 0, 0.45); line-height: 1.6;
}

.suggestions-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.suggestions-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggestion-chip {
  padding: 18rpx 28rpx;
  background: #f4f6f8;
  border-radius: 16rpx;
  font-size: 28rpx; color: #1a1a1a;
  border: 1rpx solid #e8e8ed;
}

.suggestion-chip:active { background: #e8e8ed; }

.msg-row { margin-bottom: 20rpx; display: flex; align-items: flex-end; gap: 12rpx; }
.msg-row.user { flex-direction: row-reverse; }
.msg-row.assistant { flex-direction: row; }

.avatar {
  width: 60rpx; height: 60rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; flex-shrink: 0;
}
.avatar.user { background: #e8f5e9; }
.avatar.assistant { background: #e3f2fd; }

.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx; line-height: 1.7;
  word-break: break-all; overflow: hidden;
}
.bubble.user { background: #07c05f; color: #fff; border-bottom-right-radius: 6rpx; }
.bubble.assistant { background: #fff; color: #1a1a1a; border-bottom-left-radius: 6rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }

.bubble-text { white-space: pre-wrap; }
.typing { opacity: 0.6; font-size: 26rpx; }

.thinking-box {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.thinking-header {
  font-size: 22rpx;
  color: #8e8e93;
  margin-bottom: 6rpx;
}

.thinking-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  line-height: 1.6;
  white-space: pre-wrap;
}

.input-fixed {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 12rpx 28rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: #fff; border-top: 1rpx solid #e8e8ed; z-index: 50;
}
.input-row { display: flex; align-items: flex-end; gap: 12rpx; }
.input-box {
  flex: 1; box-sizing: border-box;
  min-height: 72rpx; max-height: 200rpx;
  padding: 14rpx 24rpx;
  border: 1rpx solid #e8e8ed; border-radius: 36rpx;
  background: #f7f8fa; font-size: 28rpx; color: #1a1a1a; line-height: 1.5;
}
.send {
  flex-shrink: 0; width: 72rpx; height: 72rpx;
  margin: 0 !important; padding: 0;
  border-radius: 50%; background: #07c05f; color: #fff;
  font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
}
.send[disabled] { background: #e8e8ed; }
.send[disabled] text { color: #8e8e93; }
